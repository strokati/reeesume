# =============================================================================
# Reeesume — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────

# Local dev (matches docker-compose.dev.yml defaults):
DATABASE_URL="postgresql://reeesume:reeesume@localhost:5432/reeesume"

# Production Docker (matches docker-compose.yml — usually unchanged):
# DATABASE_URL="postgresql://reeesume:reeesume@db:5432/reeesume"

# ─── Auth ─────────────────────────────────────────────────────────────────────

# AUTH_MODE controls whether authentication is enabled.
#   "none"       — Local mode: no login screen, no sessions. App opens directly.
#   "email_otp"  — Self-hosted mode: passwordless OTP sent to ALLOWED_EMAIL.
AUTH_MODE="none"

# Required when AUTH_MODE=email_otp
# Only this email address may log in.
ALLOWED_EMAIL=""

# Required when AUTH_MODE=email_otp
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# App URL (used by Auth.js for redirect URLs and OTP links)
NEXTAUTH_URL="http://localhost:3000"

# Auth session expiry in days (default: 30)
SESSION_DURATION_DAYS=30

# ─── SMTP (required when AUTH_MODE=email_otp) ─────────────────────────────────

# For local dev: point at Mailhog (docker-compose.dev.yml spins it up)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Reeesume <noreply@reeesume.local>"

# For production self-hosted: use your own SMTP service (e.g. Gmail, Mailgun, etc.)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="you@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="Reeesume <you@gmail.com>"

# ─── Notes ────────────────────────────────────────────────────────────────────
# AI provider API keys are NOT stored here.
# They are entered by the user in Settings > AI Providers and stored in the database.
