{
	"includeCoAuthoredBy": false,
	"gitAttribution": false,
	"permissions": {
		"allow": [
			"npm run *",
			"npm install *",
			"npm install",
			"npx prisma generate",
			"npx prisma migrate dev*",
			"npx prisma studio",
			"npx prisma db seed",
			"npx prisma db push",
			"npx shadcn*",
			"npx create-next-app*",
			"docker compose up*",
			"docker compose down*",
			"docker compose logs*",
			"docker compose build*",
			"docker compose -f*",
			"git add *",
			"git commit *",
			"git status",
			"git diff *",
			"git log *",
			"git branch *",
			"git checkout *",
			"git stash *",
			"mkdir -p *",
			"cp *",
			"mv *"
		],
		"deny": [
			"git push *",
			"git push",
			"git reset --hard *",
			"git reset --hard",
			"rm -rf *",
			"npx prisma migrate reset",
			"DROP TABLE*",
			"DROP DATABASE*"
		]
	}
}
